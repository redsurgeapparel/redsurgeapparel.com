---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 6);
---

<LandingLayout
  title="Red Surge Apparel — What to wear for any event"
  description="Outfit ideas for concerts, parties, and real-life events. Simple guides to help you know exactly what to wear."
  image="/og-default.svg"
>

  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator descriptionClass="max-w-3xl">
    <Badge slot="badge" variant="brand" pill>
      Red Surge Apparel
    </Badge>

    <h1 slot="title">
      <span class="text-foreground">What to wear,</span><br />
      <span class="text-brand-500">wherever you're going</span>
    </h1>

    <p slot="description">
      Outfit ideas for concerts, nights out, and everything in between. Simple, practical, and built for real situations — not runways.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="/blog">
        Browse outfit guides
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Categories -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">

      <div class="text-center flex flex-col items-center gap-4">
        <Badge variant="brand" pill>Categories</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Find your situation
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl">
          Start with where you're going.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">

        <!-- Concerts -->
        <Card hover href="/blog">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="music" size="sm" />
            </div>
            <div>
              <h3 class="text-base font-semibold text-foreground">Concerts</h3>
              <p class="text-sm text-foreground-muted mt-1.5">
                What to wear to hip-hop, country, rock, and more.
              </p>
            </div>
          </div>
        </Card>

        <!-- Nights Out -->
        <Card hover href="/blog">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="moon" size="sm" />
            </div>
            <div>
              <h3 class="text-base font-semibold text-foreground">Nights Out</h3>
              <p class="text-sm text-foreground-muted mt-1.5">
                Clubs, parties, and going out — without overthinking it.
              </p>
            </div>
          </div>
        </Card>

        <!-- Seasonal -->
        <Card hover href="/blog">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="sun" size="sm" />
            </div>
            <div>
              <h3 class="text-base font-semibold text-foreground">Seasonal</h3>
              <p class="text-sm text-foreground-muted mt-1.5">
                Summer, winter, and everything in between.
              </p>
            </div>
          </div>
        </Card>

      </div>
    </div>
  </section>

  <!-- About -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <Badge variant="brand" pill>About</Badge>

      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mt-6 mb-6">
        Style shouldn't be complicated
      </h2>

      <p class="text-lg text-foreground-muted leading-relaxed">
        Red Surge is built around one simple idea: knowing what to wear shouldn't take hours.
        Every guide breaks down real situations and gives you outfits that actually work.
      </p>
    </div>
  </section>

  <!-- Blog -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">

      <div class="flex items-end justify-between">
        <div class="flex flex-col gap-4">
          <Badge variant="brand" pill>Latest</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            New outfit guides
          </h2>
        </div>

        <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600">
          View all
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            author={post.data.author}
            image={post.data.image}
            svgSlug={post.data.svgSlug}
          />
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-2xl px-6 text-center">

      <h2 class="font-display text-4xl font-bold text-foreground mb-4">
        Not sure what to wear?
      </h2>

      <p class="text-lg text-foreground-muted mb-8">
        Start with your event — we’ll help you figure it out.
      </p>

      <Button size="lg" href="/blog">
        Explore guides
        <Icon name="arrow-right" size="sm" />
      </Button>

    </div>
  </section>

</LandingLayout>