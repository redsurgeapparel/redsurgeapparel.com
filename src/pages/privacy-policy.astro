---
import LandingLayout from '@/layouts/LandingLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<LandingLayout
  title="Privacy Policy"
  description="Learn how Red Surge Apparel collects, uses, and protects your information."
  noindex
>
  <section
    class="relative flex min-h-[calc(100vh-8rem)] items-center justify-center overflow-hidden pt-16"
  >
    <!-- Background Effects -->
    <div
      class="bg-grid-pattern pointer-events-none absolute inset-0 [mask-image:radial-gradient(ellipse_at_center,white_20%,transparent_70%)] opacity-40"
    >
    </div>
    <div
      class="bg-brand-500/15 pointer-events-none absolute top-1/4 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full blur-[120px]"
    >
    </div>
    <div
      class="bg-brand-600/10 pointer-events-none absolute right-1/4 bottom-1/4 h-[400px] w-[400px] rounded-full blur-[100px]"
    >
    </div>

    <div class="relative container px-6">
      <div class="mx-auto max-w-3xl">
        <h1 class="font-display text-foreground mb-6 text-center text-3xl font-bold md:text-4xl">
          Privacy Policy
        </h1>

        <div class="text-foreground-muted space-y-6 text-base leading-relaxed">
          <p>
            This Privacy Policy describes how information is collected, used, and protected when you
            visit this website.
          </p>

          <h2 class="text-foreground text-xl font-semibold">Information We Collect</h2>
          <p>
            We may collect basic information such as your IP address, browser type, pages visited,
            and time spent on the site. This helps us understand how visitors use the site and
            improve the experience.
          </p>

          <h2 class="text-foreground text-xl font-semibold">Cookies</h2>
          <p>
            This site may use cookies to enhance user experience, analyze traffic, and support
            advertising. Cookies are small files stored on your device that help improve
            functionality and performance.
          </p>

          <h2 class="text-foreground text-xl font-semibold">Analytics</h2>
          <p>
            We may use analytics tools (such as Google Analytics) to understand how visitors
            interact with the site. These tools may collect anonymized usage data.
          </p>

          <h2 class="text-foreground text-xl font-semibold">Advertising</h2>
          <p>
            Third-party vendors, including Mediavine, may use cookies and similar technologies to
            serve ads based on your visits to this and other websites.
          </p>

          <h2 class="text-foreground text-xl font-semibold">Your Choices</h2>
          <p>
            You can choose to disable cookies through your browser settings. Doing so may affect how
            certain features of the site function.
          </p>

          <h2 class="text-foreground text-xl font-semibold">Changes</h2>
          <p>
            This policy may be updated from time to time. Continued use of the site indicates
            acceptance of any changes.
          </p>

          <h2 class="text-foreground text-xl font-semibold">Contact</h2>
          <p>
            If you have any questions about this Privacy Policy, you can contact us through the
            website.
          </p>
        </div>

        <!-- CTA -->
        <div class="mt-10 flex justify-center">
          <Button href="/" size="lg"> Back to home </Button>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
