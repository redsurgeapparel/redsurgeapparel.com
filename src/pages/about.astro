---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
---

<PageLayout
  title="About Red Surge — Outfit guides for real situations"
  description="Learn what Red Surge is about and how it helps you figure out what to wear for concerts, events, and everyday situations."
>
  <!-- Hero -->
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user" size="sm" />
      About
    </Badge>

    <h1 slot="title">
      <span class="text-foreground">About</span><br />
      <span class="text-brand-500">Red Surge</span>
    </h1>

    <p slot="description">A simple idea: knowing what to wear shouldn’t be complicated.</p>
  </Hero>

  <!-- What this is -->
  <section class="bg-background-secondary border-border border-t py-[var(--space-section-md)]">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <Badge variant="brand" pill>What this is</Badge>

      <h2 class="font-display text-foreground mt-6 mb-6 text-3xl font-bold md:text-4xl">
        Outfit guides for real situations
      </h2>

      <p class="text-foreground-muted mb-4 text-lg leading-relaxed">
        Red Surge is built to help you figure out what to wear for specific situations — concerts,
        nights out, parties, and everything in between.
      </p>

      <p class="text-foreground-muted text-lg leading-relaxed">
        No overcomplicated styling advice. No runway looks that don’t translate to real life. Just
        outfits that actually make sense.
      </p>
    </div>
  </section>

  <!-- How to use -->
  <section class="border-border border-t py-[var(--space-section-md)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-10 text-center">
        <Badge variant="brand" pill>How it works</Badge>

        <h2 class="font-display text-foreground mt-6 text-3xl font-bold md:text-4xl">
          Start with your event
        </h2>

        <p class="text-foreground-muted mx-auto mt-4 max-w-2xl text-lg">
          Every post is built around a real situation — so you can quickly find what you need.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <Card hover>
          <div class="flex items-start gap-4">
            <Icon name="music" class="text-brand-500 mt-1 h-6 w-6" />
            <div>
              <h3 class="text-foreground font-semibold">Concerts</h3>
              <p class="text-foreground-muted mt-1.5 text-sm">
                Hip-hop, country, rock — different vibes, different fits.
              </p>
            </div>
          </div>
        </Card>

        <Card hover>
          <div class="flex items-start gap-4">
            <Icon name="moon" class="text-brand-500 mt-1 h-6 w-6" />
            <div>
              <h3 class="text-foreground font-semibold">Nights Out</h3>
              <p class="text-foreground-muted mt-1.5 text-sm">
                Clubs, parties, and going out without overthinking it.
              </p>
            </div>
          </div>
        </Card>

        <Card hover>
          <div class="flex items-start gap-4">
            <Icon name="sun" class="text-brand-500 mt-1 h-6 w-6" />
            <div>
              <h3 class="text-foreground font-semibold">Seasonal</h3>
              <p class="text-foreground-muted mt-1.5 text-sm">
                What works in summer, winter, and everything in between.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="bg-background-secondary border-border border-t py-[var(--space-section-md)]">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <Badge variant="brand" pill>Approach</Badge>

      <h2 class="font-display text-foreground mt-6 mb-6 text-3xl font-bold md:text-4xl">
        Keep it simple
      </h2>

      <p class="text-foreground-muted mb-4 text-lg leading-relaxed">
        Most people don’t need more options — they need better ones.
      </p>

      <p class="text-foreground-muted text-lg leading-relaxed">
        The goal isn’t to overwhelm you with choices. It’s to give you a few solid outfits that
        work, so you can move on and focus on your day.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-background border-border border-t py-[var(--space-section-md)]">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="font-display text-foreground mb-4 text-4xl font-bold">Not sure what to wear?</h2>

      <p class="text-foreground-muted mb-8 text-lg">
        Start with your event — we’ll help you figure it out.
      </p>

      <Button size="lg" href="/blog">
        Browse outfit guides
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </section>
</PageLayout>
